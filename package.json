{
  "name": "express-di",
  "version": "1.0.0",
  "description": "Express dependency injection practice",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "dev": "nodemon app/index.js",
    "app::build": "docker build -t express-di .",
    "app::run": "docker run --name express-di --rm -d -p 4000:4000 -v $(pwd):/app --env-file .env -v /app/node_modules express-di",
    "app::stop": "docker stop express-di",
    "app::remove": "docker rm express-di",
    "app::logs": "docker logs express-di",
    "app::ps": "docker ps",
    "app::exec": "docker exec -it express-di /bin/sh",
    "app::attach": "docker attach express-di"
  },
  "author": "",
  "license": "ISC",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "awilix": "^13.0.3",
    "awilix-express": "^11.0.1",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "http-error": "^0.0.6",
    "jsonwebtoken": "^9.0.3",
    "nodemon": "^3.1.14",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "supertest": "^7.2.2",
    "vitest": "^0.34.6"
  }
}
